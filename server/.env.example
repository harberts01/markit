# ──────────────────────────────────────────────────────────────────────────────
# MarkIt Server — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ──────────────────────────────────────────────────────────────────────────────

# Database
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://markit_user:changeme@localhost:5432/markit

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-byte-random-hex-string

# Server
PORT=3001

# CORS — must match your frontend origin exactly (no trailing slash)
# Development:  http://localhost:3000
# Production:   https://markit.yourdomain.com
CORS_ORIGIN=http://localhost:3000

# File uploads — absolute path in production, relative in dev
UPLOAD_DIR=./uploads

# Node environment
NODE_ENV=development
